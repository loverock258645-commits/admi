{
  "name": "hospital-record-summary-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.scripts.json",
    "hash-password": "node scripts/hash-password.mjs",
    "deidentify:local": "tsx scripts/deidentify-local.ts",
    "test:fixtures": "tsc -p tsconfig.test.json && node dist-test/tests/run-fixture-tests.js",
    "test:pdf-fixtures": "tsc -p tsconfig.test.json && node dist-test/tests/run-pdf-fixture-tests.js",
    "test:local-deidentify": "tsc -p tsconfig.test.json && node dist-test/tests/run-local-deidentify-tests.js",
    "test:security-workflow": "tsc -p tsconfig.test.json && node dist-test/tests/run-security-workflow-tests.js",
    "test:openai-output": "tsc -p tsconfig.test.json && node dist-test/tests/run-openai-output-tests.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
