# OpenAI API Key。只放後端環境變數，不可放到前端程式碼。
OPENAI_API_KEY=

# 可選：指定 OpenAI 模型；不填時程式預設使用 gpt-4.1-mini。
OPENAI_MODEL=gpt-4.1-mini

# JWT 登入簽章密鑰。請使用至少 32 字元以上的隨機字串。
JWT_SECRET=

# 只允許登入的一組帳號。
APP_USERNAME=

# bcrypt 密碼雜湊，不可填明碼密碼。
# 產生方式：npm run hash-password -- 你的登入密碼
APP_PASSWORD_HASH=

# 本機開發使用 development；部署到 Render/Railway/Fly.io 時請改 production。
NODE_ENV=development

# 後端服務 port。雲端平台通常會自動指定 PORT。
PORT=3000
